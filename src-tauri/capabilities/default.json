{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main and overlay windows",
  "windows": ["main", "overlay"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "sql:default",
    "sql:allow-execute",
    "sql:allow-load",
    "sql:allow-select",
    "updater:default"
  ]
}
